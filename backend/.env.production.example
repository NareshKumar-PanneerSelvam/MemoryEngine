# Database (Supabase Postgres)
DATABASE_URL=postgresql://postgres:YOUR_URL_ENCODED_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# JWT Configuration
JWT_SECRET=replace-with-a-strong-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_TOKENS=2048
GEMINI_TEMPERATURE=0.7
AI_RATE_LIMIT_PER_MINUTE=15
AI_RATE_LIMIT_PER_DAY=1500

# CORS (set to your deployed frontend domains)
CORS_ORIGINS=https://memory-engine-seven.vercel.app
# Optional: allow Vercel preview deploy URLs
# CORS_ORIGIN_REGEX=^https://memory-engine-seven(-[a-z0-9-]+)?\\.vercel\\.app$
CORS_ORIGIN_REGEX=

# Environment
ENVIRONMENT=production
